# Rendered / assembled output (build artifacts)
_site/
_book/
.quarto/
site_libs/
!labs/_freeze/site_libs/
!labs/_freeze/site_libs/**

# Quarto computation cache (_freeze) is intentionally COMMITTED so the site
# rebuilds in CI without re-executing R. Do not ignore it.

# R / IDE
.Rproj.user/
*.Rproj
.Rhistory
.RData
.Ruserdata

# OS
.DS_Store
Thumbs.db

# Local editor / tooling config (not part of the course materials)
.claude/
.vscode/
.idea/

# Python bytecode
__pycache__/
*.pyc

# Stray render / build logs
*-render.txt

# practice/ quiz book — internal/dev files kept locally but not published.
